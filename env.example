# ============================================================================
# FastAPI_AI_chat - Environment Variables Example
# ============================================================================
# Скопируйте этот файл в .env и заполните реальные значения
# cp env.example .env

# ============================================================================
# БАЗА ДАННЫХ (PostgreSQL)
# ============================================================================
# Формат: postgresql+asyncpg://user:password@host:port/database
POSTGRESQL=postgresql+asyncpg://user:your_secure_password_here@localhost:5432/db_name

# Postgres settings for docker-compose
POSTGRES_USER=user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=db_name

# ============================================================================
# JWT АУТЕНТИФИКАЦИЯ
# ============================================================================
# Секретный ключ для подписи JWT токенов (сгенерируйте новый!)
# Совет: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_generate_with_python_command_above
ALGORITHM=HS256

# ============================================================================
# LLM API (OpenRouter / OpenAI)
# ============================================================================
# Openai API
OPENAI_API_KEY=sk-openai-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Openrouter API
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model from openrouter: google/gemini-3-flash-preview, anthropic/claude-3.5-sonnet, etc.
MODEL=google/gemini-2.5-flash-lite-preview-09-2025

# ============================================================================
# СИСТЕМА ПАМЯТИ (mem0ai)
# ============================================================================

# API ключ для mem0ai онлайн сервиса
# Получите на https://platform.mem0.ai/
API_MEM0_ONLINE=m0-your-mem0-key-here
# Memory settings
MODEL_FOR_MEMO=google/gemini-2.5-flash-lite-preview-09-2025
MEMORY_COLLECTION_PREFIX=mem0_memories

# ============================================================================
# OLLAMA (Embedding Model)
# ============================================================================

# URL Ollama сервера для генерации embedding'ов
# Локально: http://localhost:11434
# Docker: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Название модели для embedding
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Размерность embedding вектора
# nomic-embed-text: 768
# mxbai-embed-large: 1024
EMBEDDING_DIMS=768

# ============================================================================
# QDRANT (Векторная база данных)
# ============================================================================

# API ключ Qdrant Cloud (или пустой для локального)
# Получите на https://cloud.qdrant.io/
QDRANT_API_KEY=your-qdrant-cloud-key-here

# URL Qdrant сервера
# Локально: http://localhost:6333
# Docker: http://qdrant:6333
# Cloud: https://your-cluster.qdrant.io
QDRANT_BASE_URL=http://localhost:6333

# Название коллекции в Qdrant
QDRANT_COLLECTION_NAME=main_app

# ============================================================================
# NEO4J (Графовая база данных)
# ============================================================================

# Пароль для Neo4j (default: neo4j)
# После первого входа измените на свой!
NEO4J_PASSWORD=your_neo4j_password_here

# URL подключения к Neo4j
# Локально: bolt://localhost:7687
# Docker: bolt://neo4j:7687
NEO4J_BASE_URL=bolt://localhost:7687

# Имя пользователя Neo4j
NEO4J_USERNAME=neo4j

# Название базы данных в Neo4j
NEO4J_DATABASE=neo4j

# ============================================================================
# REDIS (Кэширование и Rate Limiting)
# ============================================================================

# Пароль Redis (ОБЯЗАТЕЛЕН для docker-compose.prod.yml)
# Для локальной разработки можно оставить пустым
REDIS_PASSWORD=

# URL подключения к Redis
# Локально без пароля: redis://localhost:6379
# Локально с паролем: redis://:password@localhost:6379
# Docker: redis://:password@redis:6379
REDIS_URL=redis://:your_redis_password@localhost:6379

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery настройки (используют Redis как broker)
CELERY_BROKER_URL=redis://:your_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_redis_password@localhost:6379/2
LOCK_REDIS_URL=redis://:your_redis_password@localhost:6379/3

# ============================================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================================

# Разрешённые источники запросов через запятую
# Development: http://localhost:3000,http://localhost:8080
# Production: https://mydomain.com,https://app.mydomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://127.0.0.1:8000

# ============================================================================
# ОКРУЖЕНИЕ
# ============================================================================

# Режим отладки (True для разработки, False для продакшена)
DEBUG=True

# ============================================================================
# ОПЦИОНАЛЬНО: Логирование
# ============================================================================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# ПРОДАКШЕН РЕКОМЕНДАЦИИ
# ============================================================================

# 1. Измените SECRET_KEY на случайно сгенерированный
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Установите DEBUG=False
# 3. Укажите правильные CORS_ORIGIN
# 4. Установите REDIS_PASSWORD (обязательно для docker-compose.prod.yml)
# 5. Используйте Docker Secrets для паролей
# 6. Настройте HTTPS для всех внешних сервисов
# 7. Используйте облачные версии Qdrant/Neo4j для продакшена
# 8. Настройте бэкапы для PostgreSQL и Redis
# 9. Используйте мониторинг (Prometheus, Grafana)
